LLM_API_KEY=your_key_here
LLM_BASE_URL=https://your-provider.example/v1
LLM_MODEL=gpt-4o-mini

# Default (offline, no external embedding service/model download needed)
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=hash-384

# Optional: higher quality local embedding (requires access to huggingface.co)
# EMBEDDING_PROVIDER=hf
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: remote OpenAI-compatible embeddings endpoint
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=your_embedding_key_optional
# EMBEDDING_BASE_URL=https://your-embedding-endpoint/v1
